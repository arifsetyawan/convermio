{
  "name": "convermio",
  "version": "1.0.1",
  "description": "A TypeScript currency pair amount calculator with support for different rates and arrangements",
  "main": "dist/currency-calculator.js",
  "types": "dist/currency-calculator.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "demo": "npm run build && node dist/currency-calculator.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "publish:dry": "npm publish --dry-run",
    "release:patch": "bash scripts/publish.sh patch",
    "release:minor": "bash scripts/publish.sh minor",
    "release:major": "bash scripts/publish.sh major"
  },
  "files": [
    "dist/currency-calculator.js",
    "dist/currency-calculator.js.map",
    "dist/currency-calculator.d.ts",
    "dist/currency-calculator.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/arifsetyawan/convermio.git"
  },
  "bugs": {
    "url": "https://github.com/arifsetyawan/convermio/issues"
  },
  "homepage": "https://github.com/arifsetyawan/convermio#readme",
  "keywords": [
    "currency",
    "exchange",
    "calculator",
    "forex",
    "cryptocurrency",
    "typescript"
  ],
  "author": "Arif Setyawan <me@arifsetyawan.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.0.0"
  }
}
